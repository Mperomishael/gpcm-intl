                    <h2 class="font-serif text-5xl font-bold mb-10">Get In Touch</h2>
                    <form id="contact-form" class="space-y-8">
                        <div class="grid grid-cols-2 gap-6">
                            <input type="text" placeholder="Your Name" class="bg-zinc-100 border-0 focus:ring-2 focus:ring-violet-400 rounded-2xl px-7 py-6 outline-none">
                            <input type="email" placeholder="Email Address" class="bg-zinc-100 border-0 focus:ring-2 focus:ring-violet-400 rounded-2xl px-7 py-6 outline-none">
                        </div>
                        <input type="tel" placeholder="Phone Number" class="w-full bg-zinc-100 border-0 focus:ring-2 focus:ring-violet-400 rounded-2xl px-7 py-6 outline-none">
                        <textarea placeholder="Your Message or Prayer Request..." rows="6" class="w-full bg-zinc-100 border-0 focus:ring-2 focus:ring-violet-400 rounded-3xl px-7 py-6 outline-none"></textarea>
                        <button type="button" onclick="submitFakeForm()" 
                                class="w-full bg-violet-600 hover:bg-violet-700 transition-colors text-white py-7 text-xl font-semibold rounded-3xl">SEND MESSAGE</button>
                    </form>
                </div>
                
                <!-- Info -->
                <div class="space-y-10 pt-8">
                    <div class="flex gap-6">
                        <div class="w-14 h-14 bg-violet-100 text-violet-600 rounded-2xl flex items-center justify-center text-3xl flex-shrink-0">
                            📍
                        </div>
                        <div>
                            <div class="font-semibold text-lg">#3 Oharisi Street, Opposite Central Garage, Ughelli, Delta State</div>
                        </div>
                    </div>
                    <div class="flex gap-6">
                        <div class="w-14 h-14 bg-violet-100 text-violet-600 rounded-2xl flex items-center justify-center text-3xl flex-shrink-0">
                            📞
                        </div>
                        <div>
                            <div class="font-semibold text-lg">+234 815 601 3387</div>
                            <div class="font-semibold text-lg">+234 806 939 0490</div>
                        </div>
                    </div>
                    <div class="flex gap-6">
                        <div class="w-14 h-14 bg-violet-100 text-violet-600 rounded-2xl flex items-center justify-center text-3xl flex-shrink-0">
                            ✉️
                        </div>
                        <div class="font-semibold text-lg">support@glowingpalaceministry.org</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="bg-zinc-950 text-zinc-400">
        <div class="max-w-7xl mx-auto px-6 pt-20 pb-12">
            <div class="grid md:grid-cols-4 gap-10">
                <div>
                    <div class="flex items-center gap-3 text-white mb-6">
                        <div class="w-9 h-9 bg-white rounded-2xl"></div>
                        <div class="font-serif text-3xl font-bold text-white">GPCM INT'L</div>
                    </div>
                    <p class="text-sm leading-relaxed">A vibrant Spirit-filled community dedicated to worship, discipleship, and community transformation.</p>
                </div>
                
                <div>
                    <div class="uppercase text-xs tracking-widest mb-6 text-white">Quick Links</div>
                    <div class="space-y-3 text-sm">
                        <div><a href="#" class="hover:text-white transition-colors">About Us</a></div>
                        <div><a href="#" class="hover:text-white transition-colors">Ministries</a></div>
                        <div><a href="#" class="hover:text-white transition-colors">Events</a></div>
                    </div>
                </div>
                
                <div>
                    <div class="uppercase text-xs tracking-widest mb-6 text-white">Bank Details</div>
                    <div class="text-sm bg-white/5 p-6 rounded-3xl">
                        <div><span class="text-amber-300">Acct:</span> 8817008125</div>
                        <div class="mt-1"><span class="text-amber-300">Name:</span> GPCM INT'L</div>
                        <div class="mt-4 text-xs">Sterling Bank</div>
                    </div>
                </div>
                
                <div>
                    <div class="uppercase text-xs tracking-widest mb-6 text-white">Connect</div>
                    <div class="flex gap-4 text-3xl">
                        <i class="fa-brands fa-facebook hover:text-white cursor-pointer transition-colors"></i>
                        <i class="fa-brands fa-instagram hover:text-white cursor-pointer transition-colors"></i>
                        <i class="fa-brands fa-youtube hover:text-white cursor-pointer transition-colors"></i>
                    </div>
                </div>
            </div>
            
            <div class="text-center text-xs mt-20 pt-8 border-t border-white/10">
                © 2026 Glowing Palace of Christian Ministry International. All Rights Reserved.
            </div>
        </div>
    </footer>

    <!-- WhatsApp Float -->
    <a href="https://wa.me/2348069390490" target="_blank"
       class="fixed bottom-8 right-8 bg-green-500 text-white w-16 h-16 rounded-3xl shadow-2xl flex items-center justify-center text-4xl z-50 hover:scale-110 active:scale-95 transition-all">
        <i class="fa-brands fa-whatsapp"></i>
    </a>

    <!-- Modals -->
    <div id="live-modal" class="hidden fixed inset-0 bg-black/90 z-[100] flex items-center justify-center">
        <div class="bg-white rounded-3xl max-w-lg w-full mx-4 overflow-hidden">
            <div class="p-8">
                <h3 class="text-3xl font-serif">Sunday Service Live</h3>
                <p class="text-zinc-500 mt-2">10:00 AM - 12:30 PM WAT</p>
                <div class="mt-8 bg-zinc-100 h-64 rounded-2xl flex items-center justify-center">
                    <div class="text-center">
                        <i class="fa-solid fa-video text-6xl text-zinc-300 mb-4"></i>
                        <p class="text-zinc-400">Live stream coming soon</p>
                    </div>
                </div>
            </div>
            <div class="border-t flex">
                <button onclick="hideLiveModal()" class="flex-1 py-6 text-zinc-500 font-medium">Close</button>
            </div>
        </div>
    </div>

    <script>
        // Tailwind script already loaded
        function initializeTailwind() {
            // Nothing extra needed
        }
        
        // Hero Slides
        const heroSlides = [
            {
                title: "Welcome to GPCM INT'L",
                subtitle: "A place where lives are transformed",
                image: "https://i.ibb.co/C30xt8n2/IMG-20250925-113020.jpg"
            },
            {
                title: "Experience God's Glory",
                subtitle: "Join us in worship and fellowship",
                image: "https://i.ibb.co/wF3QSv9W/IMG-20251030-111101.jpg"
            },
            {
                title: "Transforming Communities",
                subtitle: "Through the power of the Gospel",
                image: "https://i.ibb.co/JPXkn95/IMG-20251030-114723.jpg"
            }
        ]
        
        let currentSlide = 0
        
        function renderHero() {
            const container = document.getElementById('hero-slides')
            container.innerHTML = ''
            
            heroSlides.forEach((slide, i) => {
                const div = document.createElement('div')
                div.className = `hero-slide absolute inset-0 bg-cover bg-center transition-opacity duration-1000 ${i === 0 ? 'opacity-100' : 'opacity-0'}`
                div.style.backgroundImage = `url('${slide.image}')`
                container.appendChild(div)
            })
            
            // Content
            const content = document.getElementById('hero-content')
            content.innerHTML = `
                <h1 class="font-serif text-6xl md:text-7xl font-bold leading-none tracking-tighter">${heroSlides[0].title}</h1>
                <p class="max-w-xl mx-auto text-2xl">${heroSlides[0].subtitle}</p>
            `
            
            // Indicators
            const indicators = document.getElementById('slide-indicators')
            indicators.innerHTML = heroSlides.map((_, i) => `
                <button onclick="goToSlide(${i})" class="w-3 h-3 rounded-full transition-all ${i === 0 ? 'bg-white scale-125' : 'bg-white/40'}"></button>
            `).join('')
        }
        
        function goToSlide(n) {
            currentSlide = n
            const slides = document.querySelectorAll('.hero-slide')
            slides.forEach((s, i) => {
                s.style.opacity = i === currentSlide ? '1' : '0'
            })
        }
        
        // Auto rotate hero
        setInterval(() => {
            currentSlide = (currentSlide + 1) % heroSlides.length
            goToSlide(currentSlide)
        }, 6500)
        
        function copyAccount() {
            navigator.clipboard.writeText("8817008125")
            const notif = document.createElement('div')
            notif.textContent = "✅ Account number copied!"
            notif.style.cssText = 'position:fixed;bottom:100px;right:30px;background:#10b981;color:white;padding:16px 24px;border-radius:9999px;z-index:999'
            document.body.appendChild(notif)
            setTimeout(() => notif.remove(), 2500)
        }
        
        function showLiveModal() {
            document.getElementById('live-modal').classList.remove('hidden')
            document.getElementById('live-modal').classList.add('flex')
        }
        
        function hideLiveModal() {
            const modal = document.getElementById('live-modal')
            modal.classList.add('hidden')
            modal.classList.remove('flex')
        }
        
        function submitFakeForm() {
            alert("✅ Thank you! Your message has been received. We will get back to you shortly.")
        }
        
        function toggleMobileMenu() {
            const menu = document.getElementById('mobile-menu')
            menu.classList.toggle('hidden')
        }
        
        function smoothScrollTo(section) {
            document.getElementById(section).scrollIntoView({ behavior: "smooth" })
        }
        
        // Gallery images
        const galleryImages = [
            "https://i.ibb.co/8nk0rjz1/20251006-065800.png",
            "https://i.ibb.co/1tyF9xV6/20251006-065939.jpg",
            "https://i.ibb.co/sJvHDNwM/IMG-20250918-111813.jpg",
            "https://i.ibb.co/r2Z4dp3Y/IMG-20250918-112026.jpg",
            "https://i.ibb.co/C30xt8n2/IMG-20250925-113020.jpg",
            "https://i.ibb.co/wF3QSv9W/IMG-20251030-111101.jpg"
        ]
        
        function renderGallery() {
            const grid = document.getElementById('gallery-grid')
            grid.innerHTML = galleryImages.map(src => `
                <div onclick="showImageModal('${src}')" class="aspect-square rounded-3xl overflow-hidden cursor-pointer">
                    <img src="${src}" class="w-full h-full object-cover gallery-img">
                </div>
            `).join('')
        }
        
        function showImageModal(src) {
            const modal = document.createElement('div')
            modal.style.cssText = `
                position: fixed; inset: 0; background: rgba(0,0,0,0.95); 
                z-index: 200; display: flex; align-items: center; justify-content: center;
            `
            modal.innerHTML = `
                <div onclick="event.stopImmediatePropagation()" class="max-w-3xl w-full mx-4 relative">
                    <button onclick="this.parentElement.parentElement.remove()" 
                            class="absolute -top-4 -right-4 bg-white text-black w-10 h-10 rounded-full flex items-center justify-center text-2xl shadow">×</button>
                    <img src="${src}" class="w-full rounded-3xl shadow-2xl">
                </div>
            `
            document.body.appendChild(modal)
            modal.onclick = () => modal.remove()
        }
        
        // Keyboard ESC
        document.addEventListener('keydown', function(e) {
            if (e.key === "Escape") {
                const liveModal = document.getElementById('live-modal')
                if (!liveModal.classList.contains('hidden')) hideLiveModal()
            }
        })
        
        // Initialize everything
        window.onload = function() {
            renderHero()
            renderGallery()
            
            // Mobile menu toggle
            document.getElementById('mobile-menu-btn').addEventListener('click', toggleMobileMenu)
            
            // Close mobile menu on link click (handled in HTML onclicks)
            
            console.log('%c✅ GPCM INT\'L Single File Website Ready', 'color:#7c3aed; font-size:16px; font-weight:bold')
        }
    </script>
</body>
</html>
