                    ABOUT GPCM INT'L
                </div>
                <h2 class="font-serif text-6xl font-bold tracking-tighter">A Place of Worship,<br>Transformation &amp; Impact</h2>
            </div>
            
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- Values cards from about-section.tsx -->
                <div class="card-hover bg-white border border-zinc-100 rounded-3xl overflow-hidden group">
                    <div class="h-64 bg-cover bg-center" style="background-image: url('https://i.ibb.co/8nk0rjz1/20251006-065800.png')"></div>
                    <div class="p-8">
                        <h3 class="font-serif text-3xl font-semibold mb-3">Worship</h3>
                        <p class="text-zinc-600">Honoring God with joy and reverence in all that we do.</p>
                        <div class="mt-8 pt-6 border-t text-xs italic">"Serve the Lord with gladness..."</div>
                        <div class="text-[10px] text-zinc-400">Psalm 100:2</div>
                    </div>
                </div>
                
                <!-- More value cards (abbreviated for brevity) -->
                <div class="card-hover bg-white border border-zinc-100 rounded-3xl overflow-hidden group">
                    <div class="h-64 bg-cover bg-center" style="background-image: url('https://i.ibb.co/1tyF9xV6/20251006-065939.jpg')"></div>
                    <div class="p-8">
                        <h3 class="font-serif text-3xl font-semibold mb-3">Growth</h3>
                        <p class="text-zinc-600">Pursuing holistic development in spirit, mind, and body.</p>
                    </div>
                </div>
                
                <div class="card-hover bg-white border border-zinc-100 rounded-3xl overflow-hidden group">
                    <div class="h-64 bg-cover bg-center" style="background-image: url('https://i.ibb.co/sJvHDNwM/IMG-20250918-111813.jpg')"></div>
                    <div class="p-8">
                        <h3 class="font-serif text-3xl font-semibold mb-3">Discipleship</h3>
                        <p class="text-zinc-600">Equipping believers to serve in God's Kingdom.</p>
                    </div>
                </div>
            </div>
            
            <!-- Vision & Mission -->
            <div class="mt-20 grid md:grid-cols-2 gap-8">
                <div class="bg-gradient-to-br from-violet-50 to-amber-50 border border-violet-100 p-10 rounded-3xl">
                    <h3 class="font-serif text-4xl mb-6">Our Vision</h3>
                    <p class="text-lg leading-relaxed text-zinc-700">To see souls saved, lives transformed, and communities impacted through the love of Jesus Christ.</p>
                </div>
                <div class="bg-gradient-to-br from-amber-50 to-violet-50 border border-amber-100 p-10 rounded-3xl">
                    <h3 class="font-serif text-4xl mb-6">Our Mission</h3>
                    <p class="text-lg leading-relaxed text-zinc-700">To worship joyfully, equip the saints, proclaim the Gospel, and demonstrate Christ's love.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- GENERAL OVERSEER -->
    <section class="py-20 bg-zinc-900 text-white">
        <div class="max-w-6xl mx-auto px-6">
            <div class="grid md:grid-cols-12 gap-12 items-center">
                <div class="md:col-span-5">
                    <img src="https://i.ibb.co/zhf3LtCg/Whats-App-Image-2026-02-05-at-17-51-46.jpg" 
                         alt="Apostle Bishop Dr. Ilaya O. Clement" 
                         class="rounded-3xl shadow-2xl w-full">
                </div>
                <div class="md:col-span-7">
                    <div class="uppercase tracking-[3px] text-amber-400 text-sm font-medium mb-3">Spiritual Leadership</div>
                    <h2 class="font-serif text-5xl leading-none mb-6">Apostle Bishop Dr. Ilaya O. Clement</h2>
                    <p class="text-2xl text-amber-300 mb-8">President &amp; Founder</p>
                    
                    <p class="text-zinc-300 leading-relaxed text-lg mb-8">
                        A visionary leader, entrepreneur, and dedicated servant of God. Bishop Clement has a heart for the lost and a passion for community transformation.
                    </p>
                    
                    <div class="flex gap-4">
                        <a href="tel:+2348069390490" class="flex-1 bg-white text-zinc-900 py-6 rounded-3xl flex items-center justify-center gap-3 font-semibold text-lg hover:bg-amber-300 transition-all">
                            <i class="fa-solid fa-phone"></i>
