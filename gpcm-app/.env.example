                <div onclick="copyAccount()" class="cursor-pointer group">
                    <div class="text-5xl font-mono font-bold tracking-widest mb-1 group-active:scale-95 transition-all">8817008125</div>
                    <div class="text-zinc-400">GPCM INT'L</div>
                </div>
                
                <button onclick="copyAccount()" 
                        class="mt-8 w-full py-6 bg-white text-violet-950 rounded-2xl font-semibold flex items-center justify-center gap-3 hover:bg-amber-300 transition-all">
                    <i class="fa-solid fa-copy"></i>
                    COPY ACCOUNT NUMBER
                </button>
