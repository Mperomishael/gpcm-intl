<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GPCM INT'L - Glowing Palace of Christian Ministry International</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@400;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@400;600;700&family=Poppins:wght@300;400;500;600;700&display=swap');
        
        :root {
            --primary: #7c3aed;
            --secondary: #d97706;
        }
        
        .tail-container {
            font-family: 'Poppins', system_ui, sans-serif;
        }
        
        .font-serif {
            font-family: 'Crimson Text', serif;
        }
        
        .hero-slide {
            transition: opacity 1000ms ease-in-out;
        }
        
        .nav-link {
            position: relative;
        }
        
        .nav-link:after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: -2px;
            left: 0;
            background-color: #7c3aed;
            transition: all 0.3s ease;
        }
        
        .nav-link:hover:after {
            width: 100%;
        }
        
        .card-hover {
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .card-hover:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
        }
        
        .gallery-img {
            transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .gallery-img:hover {
            transform: scale(1.08);
        }
        
        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .animate-fade-in-down {
            animation: fadeInDown 0.7s ease-out forwards;
        }
    </style>
</head>
<body class="tail-container bg-zinc-50 text-zinc-900">
    <!-- Navigation -->
    <nav id="nav" class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-md border-b border-zinc-200 shadow-sm">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex items-center justify-between h-20">
                <!-- Logo -->
                <div class="flex items-center gap-3">
                    <div class="w-14 h-14 bg-gradient-to-br from-violet-600 to-amber-500 rounded-2xl flex items-center justify-center overflow-hidden">
                        <img src="https://i.ibb.co/images/design-mode/Whats-App-Image-2025-10-06-at-7-00-18-AM-removebg-preview.png" 
                             alt="GPCM Logo" class="w-12 h-12 object-contain">
                    </div>
                    <div>
                        <div class="font-serif text-2xl font-bold tracking-tight">GPCM INT'L</div>
                        <div class="text-xs text-zinc-500 -mt-1">Glowing Palace of Christian Ministry</div>
                    </div>
                </div>

                <!-- Desktop Menu -->
                <div class="hidden lg:flex items-center gap-10 text-sm font-medium">
                    <a href="#home" onclick="smoothScrollTo('home')" class="nav-link text-zinc-700 hover:text-violet-600 transition-colors">Home</a>
                    <a href="#about" onclick="smoothScrollTo('about')" class="nav-link text-zinc-700 hover:text-violet-600 transition-colors">About</a>
                    <a href="#ministries" onclick="smoothScrollTo('ministries')" class="nav-link text-zinc-700 hover:text-violet-600 transition-colors">Ministries</a>
                    <a href="#services" onclick="smoothScrollTo('services')" class="nav-link text-zinc-700 hover:text-violet-600 transition-colors">Services</a>
                    <a href="#gallery" onclick="smoothScrollTo('gallery')" class="nav-link text-zinc-700 hover:text-violet-600 transition-colors">Gallery</a>
                    <a href="#contact" onclick="smoothScrollTo('contact')" class="nav-link text-zinc-700 hover:text-violet-600 transition-colors">Contact</a>
                </div>

                <div class="hidden lg:flex items-center gap-4">
                    <button onclick="showLiveModal()" 
                            class="px-6 py-2.5 text-sm font-semibold border border-violet-200 hover:border-violet-300 rounded-full transition-all">
                        Watch Live
                    </button>
                    <button onclick="document.getElementById('give-section').scrollIntoView({ behavior: 'smooth' })" 
                            class="bg-violet-600 hover:bg-violet-700 text-white px-8 py-2.5 text-sm font-semibold rounded-full transition-all flex items-center gap-2">
                        <i class="fa-solid fa-heart"></i>
                        Give
                    </button>
                </div>

                <!-- Mobile Hamburger -->
                <button id="mobile-menu-btn"
                        class="lg:hidden w-10 h-10 flex items-center justify-center text-2xl">
                    <i class="fa-solid fa-bars"></i>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden lg:hidden bg-white border-t py-6 px-6">
            <div class="flex flex-col gap-6 text-lg">
                <a href="#home" onclick="toggleMobileMenu()" class="font-medium">Home</a>
                <a href="#about" onclick="toggleMobileMenu()" class="font-medium">About Us</a>
                <a href="#ministries" onclick="toggleMobileMenu()" class="font-medium">Ministries</a>
                <a href="#services" onclick="toggleMobileMenu()" class="font-medium">Services</a>
                <a href="#gallery" onclick="toggleMobileMenu()" class="font-medium">Gallery</a>
                <a href="#contact" onclick="toggleMobileMenu()" class="font-medium">Contact</a>
                
                <div class="pt-6 border-t flex flex-col gap-3">
                    <button onclick="showLiveModal();toggleMobileMenu()" 
                            class="w-full py-4 border border-violet-200 rounded-2xl font-semibold">Watch Live</button>
                    <button onclick="document.getElementById('give-section').scrollIntoView({ behavior: 'smooth' });toggleMobileMenu()" 
                            class="w-full py-4 bg-violet-600 text-white rounded-2xl font-semibold">Support Ministry</button>
                </div>
            </div>
        </div>
    </nav>

    <!-- HERO -->
    <section id="home" class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
        <div id="hero-slides" class="absolute inset-0">
            <!-- Slides populated by JS -->
        </div>
        
        <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/40 to-black/70 z-10"></div>
        
        <div class="relative z-20 max-w-5xl mx-auto px-6 text-center text-white">
            <div id="hero-content" class="space-y-6">
                <!-- Dynamic content -->
            </div>
            
            <div class="flex flex-col sm:flex-row gap-4 justify-center mt-12">
                <button onclick="document.getElementById('contact').scrollIntoView({ behavior: 'smooth' })" 
                        class="bg-white text-violet-700 hover:bg-white/90 px-10 py-4 rounded-3xl font-semibold text-lg inline-flex items-center justify-center gap-3 transition-all">
                    <i class="fa-solid fa-play"></i>
                    Join Live Service
                </button>
                <button onclick="document.getElementById('about').scrollIntoView({ behavior: 'smooth' })" 
                        class="border-2 border-white/80 hover:bg-white/10 px-10 py-4 rounded-3xl font-semibold text-lg transition-all">
                    Discover More
                </button>
            </div>
        </div>
        
        <!-- Slide indicators -->
        <div id="slide-indicators" class="absolute bottom-12 left-1/2 -translate-x-1/2 flex gap-3 z-30"></div>
    </section>

    <!-- ABOUT -->
    <section id="about" class="py-24 bg-white">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-16">
                <div class="inline-flex items-center gap-2 bg-violet-100 text-violet-700 px-6 py-2 rounded-full text-sm font-medium mb-4">
